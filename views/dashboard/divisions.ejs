<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Divisions & Lines - Andon Dashboard</title>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/dashboard.css">
    <link rel="stylesheet" href="/css/divisions.css">
</head>
<body class="has-fixed-header <%= user.role === 'manager' ? 'manager-view' : (['admin', 'management', 'maintenance', 'quality', 'engineering'].includes(user.role) ? 'admin-view' : '') %>">
    <%- include('../partials/header') %>

    <main class="dashboard-main">
        <div class="container">
            <div class="divisions-container" id="divisionsContainer">
                <div class="loading-spinner">
                    <i class="fas fa-spinner fa-spin"></i>
                    <p>Memuat data divisi dan line...</p>
                </div>
            </div>
        </div>
    </main>

    <div id="userData" data-role="<%= user.role %>" data-line="<%= user.line_name || '' %>" data-division="<%= user.division || '' %>" style="display: none;"></div>

    <audio id="alertSound" preload="auto">
        <source src="/audio/alert.mp3" type="audio/mpeg">
    </audio>

    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/moment.js/2.29.4/moment.min.js"></script>
    <script src="/socket.io/socket.io.js"></script>
    <script src="/js/header-common.js"></script>
    <script src="/js/divisions.js"></script>
    <script>
        // Hide Dashboard link on divisions page
        document.querySelectorAll('.analytics-link[href="/divisions"]').forEach(link => {
            link.style.display = 'none';
        });
    </script>
</body>
</html>

